[user]
	name = japananh
	email = japananh@gmail.com
[core]
    editor = vim
[alias]
	cm = commit -m
    cma = commit --amend --no-edit
    edit = commit --amend
	p = push
	pf = push -f
	st = status
	stp = stash pop
	chb = checkout -b
	ch = checkout
	br = branch
	brd = branch -D
	brm = branch -m
	brl = branch --list
	s = stash
	sp = stash pop
	a = add .
	rs = reset
	pdo = push -d origin
	cp = cherry-pick
	pl = pull
	f = fetch
	lo = log --oneline
    wip = !git add . && git commit -m "WIP"
    undo = reset HEAD~1
	wta = worktree add
	wtr = worktree remove
	wtl = worktree list
	rb = rebase
	rsh = reset --hard
[push]
	default = current
[init]
    defaultBranch = main
